# 4) CLI entrypoint
# ============================================================

def _extract_N_from_name(p: Path) -> int:
    m = re.search(r"N(\d+)", p.stem)
    return int(m.group(1)) if m else -1


def _autopick_lp() -> Optional[Path]:
    cands = sorted(Path(".").glob("QPLIB_style_*.lp"), key=_extract_N_from_name)
    if cands:
        return cands[-1]
    any_lp = list(Path(".").glob("*.lp"))
    if not any_lp:
        return None
    any_lp.sort(key=lambda p: p.stat().st_mtime)
    return any_lp[-1]


if __name__ == "__main__":
    import argparse
    import sys

    parser = argparse.ArgumentParser(
        description="Solve LP via D-Wave QPU -> energy-filtered marginals -> swap local search -> fixed-support QP"
    )

    parser.add_argument("lp_pos", nargs="?", default=None, help="(positional) Path to LP file.")
    parser.add_argument("--lp", default=None, help="Path to LP file (optional, overrides positional).")

    parser.add_argument("--K", type=int, default=None, help="Cardinality cap. If omitted, uses K parsed from LP.")
    parser.add_argument("--num-reads", type=int, default=3000, help="D-Wave num_reads (default: 3000)")
    parser.add_argument("--n-runs", type=int, default=1, help="How many sampling runs (default: 1)")
    parser.add_argument("--lam", type=float, default=10.0, help="Penalty weight scale (default: 10.0)")

    parser.add_argument("--verbose", action="store_true", help="Enable INFO logs")
    parser.add_argument("--qp-verbose", action="store_true", help="Enable CVXPY solver verbose logs (debug)")

    # BQM normalization knobs
    parser.add_argument("--bqm-maxabs-target", type=float, default=1.0, help="Scale BQM so max |bias| ~= target (default: 1.0)")
    parser.add_argument("--auto-scale", action="store_true", help="Let D-Wave auto_scale (default: False if we normalize ourselves)")

    # marginal knobs
    parser.add_argument("--marginal-best-frac", type=float, default=0.2, help="Use lowest-energy states covering this occ-mass fraction (default: 0.2)")
    parser.add_argument("--no-marginal-plot", action="store_true", help="Disable marginal plot")
    parser.add_argument("--marginal-plot-top-m", type=int, default=60, help="Plot top-M marginals (default: 60)")

    # local search knobs (default ON)
    parser.add_argument("--ls-iters", type=int, default=20, help="Swap local search iterations (default: 20)")
    parser.add_argument("--ls-active-pool", type=int, default=8, help="Candidates to remove (lowest p among active) (default: 8)")
    parser.add_argument("--ls-inactive-pool", type=int, default=64, help="Candidates to add (highest p among inactive) (default: 64)")
    parser.add_argument("--ls-tol", type=float, default=1e-10, help="Improvement tolerance (default: 1e-10)")
    parser.add_argument("--ls-first-improve", action="store_true", help="Use first-improvement instead of best-improvement")

    # D-Wave parameters
    parser.add_argument("--annealing-time", type=int, default=20, help="D-Wave annealing_time (microseconds)")
    parser.add_argument("--chain-strength", type=float, default=None, help="D-Wave chain_strength (default: auto)")
    parser.add_argument("--num-spin-reversal-transforms", type=int, default=0, help="D-Wave num_spin_reversal_transforms")

    args = parser.parse_args()

    logging.basicConfig(
        level=(logging.INFO if args.verbose else logging.WARNING),
        format="%(levelname)s:%(name)s:%(message)s",
    )

    # choose lp path
    if args.lp is not None:
        lp_path = Path(args.lp)
    elif args.lp_pos is not None:
        lp_path = Path(args.lp_pos)
    else:
        picked = _autopick_lp()
        if picked is None:
            print("[ERROR] No LP file specified and no *.lp found in current directory.", file=sys.stderr)
            sys.exit(1)
        lp_path = picked
        if args.verbose:
            print(f"[INFO] Auto-selected LP: {lp_path}")

    if not lp_path.exists():
        print(f"[ERROR] LP file not found: {lp_path}", file=sys.stderr)
        sys.exit(1)

    print(f"[INFO] Reading LP: {lp_path.resolve()}")

    # D-Wave sampler setup
    if DWaveSampler is None or EmbeddingComposite is None:
        print(
            "[ERROR] D-Wave is required but not available.\n"
            "Install and configure:\n"
            "  pip install dwave-system\n"
            "  dwave config create",
            file=sys.stderr,
        )
        sys.exit(2)

    qpu = DWaveSampler()
    sampler_base = EmbeddingComposite(qpu)

    if args.verbose:
        try:
            print(f"[INFO] Using D-Wave QPU: {qpu.solver.name}")
        except Exception:
            print("[INFO] Using D-Wave QPU")

    class _SamplerWrapper:
        def __init__(self, base, extra_kwargs: dict[str, Any]):
            self.base = base
            self.extra_kwargs = extra_kwargs

        def sample(self, bqm, **kwargs):
            merged = dict(self.extra_kwargs)
            merged.update(kwargs)
            return self.base.sample(bqm, **merged)

    extra_qpu_kwargs: dict[str, Any] = {
        "annealing_time": int(args.annealing_time),
    }
    if args.chain_strength is not None:
        extra_qpu_kwargs["chain_strength"] = float(args.chain_strength)
    if int(args.num_spin_reversal_transforms) > 0:
        extra_qpu_kwargs["num_spin_reversal_transforms"] = int(args.num_spin_reversal_transforms)

    sampler_obj = _SamplerWrapper(sampler_base, extra_qpu_kwargs)

    out = solve_qplib_style_lp(
        lp_path=str(lp_path),
        cardinality=args.K,
        num_reads=int(args.num_reads),
        n_runs=int(args.n_runs),
        lam=float(args.lam),
        sampler=sampler_obj,
        bqm_maxabs_target=float(args.bqm_maxabs_target),
        auto_scale=bool(args.auto_scale),
        marginal_best_frac=float(args.marginal_best_frac),
        plot_marginal=(not args.no_marginal_plot),
        marginal_plot_top_m=int(args.marginal_plot_top_m),
        ls_iters=int(args.ls_iters),
        ls_active_pool=int(args.ls_active_pool),
        ls_inactive_pool=int(args.ls_inactive_pool),
        ls_tol_improve=float(args.ls_tol),
        ls_first_improve=bool(args.ls_first_improve),
        qp_verbose=bool(args.qp_verbose),
    )

    z_init = np.asarray(out["z_init"], dtype=int)
    z_hat = np.asarray(out["z_hat"], dtype=int)

    print("=== DONE ===")
    print(f"LP              : {lp_path}")
    print(f"K_card          : {out['K_card']}")
    print(f"K_eff           : {out['K_eff']}")
    print(f"K_pick          : {out['K_pick']}")

    print(f"unique_z        : {out['num_unique_z']}")
    print(f"total_occ       : {out['total_occ']}")
    print(f"marg_best_frac  : {out['marginal_best_frac']}")
    print(f"marg_occ_used   : {out['marginal_total_used']}")

    print(f"bqm_pre_maxabs  : {out['bqm_pre_maxabs']}")
    print(f"bqm_scale_factor: {out['bqm_scale_factor']}")
    print(f"bqm_target      : {out['bqm_maxabs_target']}")
    print(f"auto_scale      : {out['auto_scale']}")

    init_idx = out["active_init"]
    final_idx = out["active_final"]

    print(f"objective_init  : {out['objective_init']:.12g}")
    print(f"objective_final : {out['objective']:.12g}")

    print(f"active_init     : {init_idx[:30]}{' ...' if len(init_idx) > 30 else ''}")
    print(f"active_final    : {final_idx[:30]}{' ...' if len(final_idx) > 30 else ''}")

    if out.get("marginal_plot_path"):
        print(f"marginal_plot   : {out['marginal_plot_path']}")

    # show last LS step
    trace = out.get("ls_trace") or []
    if trace:
        last = trace[-1]
        print(f"ls_steps        : {len(trace)-1}")
        if "stop" in last:
            print(f"ls_stop         : {last['stop']}")
