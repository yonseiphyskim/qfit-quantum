    # ============================================================
    # generalized-eigen QSCI weights (overlap-aware)
    # Solve HR v = λ G v, where G = X X^T (X rows are bitstrings)
    # ============================================================
    @staticmethod
    def _qsci_generalized_weights(
        HR: np.ndarray,
        X: np.ndarray,
        tol: float = 1e-10,
        reg: float = 1e-12,
    ) -> np.ndarray:
        HR = np.asarray(HR, dtype=float)
        HR = 0.5 * (HR + HR.T)

        X = np.asarray(X, dtype=float)
        G = X @ X.T
        G = 0.5 * (G + G.T)
        G = G + float(reg) * np.eye(G.shape[0])

        gvals, U = np.linalg.eigh(G)
        keep = gvals > float(tol)
        if not np.any(keep):
            raise RuntimeError("QSCI generalized: overlap matrix G is numerically singular (no eigenvalue > tol).")

        g = gvals[keep]
        Uk = U[:, keep]
        W = Uk / np.sqrt(g)  # (R, r)

        Ht = W.T @ HR @ W
        Ht = 0.5 * (Ht + Ht.T)

        evals, evecs = np.linalg.eigh(Ht)
        y0 = evecs[:, 0]
        v0 = W @ y0

        w = (v0.real ** 2)
        sw = float(w.sum())
        if not np.isfinite(sw) or sw <= 0:
            raise RuntimeError("QSCI generalized: invalid weights (sum<=0 or non-finite).")
        w /= sw
        return w

    # -------------------------
    # plot QSCI distribution
    # -------------------------
    @staticmethod
    def _plot_qsci_distribution(
        probs: np.ndarray,
        SR: list[tuple[int, ...]],
        result_tag: str,
        out_dir: str = "qsci_plots",
        top_m: int = 30,
        save: bool = True,
        show: bool = False,
    ) -> dict[str, str]:
        if plt is None:
            raise RuntimeError("matplotlib is not available. Install with: pip install matplotlib")

        probs = np.asarray(probs, dtype=float).reshape(-1)
        R = len(probs)
        if R != len(SR):
            raise ValueError("probs and SR length mismatch")

        outp: dict[str, str] = {}
        Path(out_dir).mkdir(parents=True, exist_ok=True)

        order = np.argsort(probs)[::-1]
        m = int(min(max(1, top_m), R))
        top_idx = order[:m]
        top_probs = probs[top_idx]
        top_ks = [int(sum(SR[i])) for i in top_idx]

        labels = [f"SR#{i+1}\n(k={k})" for i, k in zip(top_idx.tolist(), top_ks)]

        plt.figure()
        plt.bar(np.arange(m), top_probs)
        plt.xticks(np.arange(m), labels, rotation=90)
        plt.ylabel("QSCI weight")
        plt.title(f"QSCI (generalized) distribution over SR (Top {m})")
        if save:
            p1 = str(Path(out_dir) / f"{result_tag}_qsci_probs_top{m}.png")
            plt.tight_layout()
            plt.savefig(p1, dpi=200)
            outp["qsci_probs_top"] = p1
        if show:
            plt.show()
        plt.close()

        ks_all = np.array([int(sum(z)) for z in SR], dtype=int)
        k_vals = np.sort(np.unique(ks_all))
        mass = np.array([probs[ks_all == kv].sum() for kv in k_vals], dtype=float)

        plt.figure()
        plt.bar(k_vals, mass)
        plt.xlabel("k = sum(z) in SR")
        plt.ylabel("probability mass")
        plt.title("QSCI probability mass by k (within SR)")
        if save:
            p2 = str(Path(out_dir) / f"{result_tag}_qsci_probmass_by_k.png")
            plt.tight_layout()
            plt.savefig(p2, dpi=200)
            outp["qsci_probmass_by_k"] = p2
        if show:
            plt.show()
        plt.close()

        return outp

    # -------------------------
    # F_tilde frequency helpers
    # -------------------------
    @staticmethod
    def _bucket_float(v: float, decimals: int = 9) -> float:
        return float(np.round(float(v), decimals=int(decimals)))

    @staticmethod
    def _plot_ftilde_frequency(
        ftilde_counter: Counter[float],
        result_tag: str,
        out_dir: str = "ftilde_plots",
        top_m: int = 80,
        save: bool = True,
