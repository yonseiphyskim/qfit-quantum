    # -------------------------
    # Robust QP solve (support fixed)
    # -------------------------
    @staticmethod
    def _solve_problem_with_fallback(prob: cp.Problem, verbose: bool = False) -> None:
        installed = set(cp.installed_solvers())
        candidates: list[tuple[str, dict[str, Any]]] = [
            ("OSQP", {"verbose": verbose, "warm_start": True, "max_iter": 200000, "eps_abs": 1e-8, "eps_rel": 1e-8}),
            ("CLARABEL", {"verbose": verbose}),
            ("ECOS", {"verbose": verbose}),
            ("SCS", {"verbose": verbose, "max_iters": 50000}),
        ]
        last_err: Optional[Exception] = None

        for name, opts in candidates:
            if name not in installed:
                continue
            try:
                prob.solve(solver=getattr(cp, name), **opts)
                return
            except Exception as e:
                last_err = e

        try:
            prob.solve(verbose=verbose)
            return
        except Exception as e:
            last_err = e

        raise cp.SolverError(f"All solvers failed. Last error: {last_err}")

    def solve_qp_with_support(
        self,
        z_hat: np.ndarray,
        verbose: bool = False,
    ) -> tuple[np.ndarray, float]:
        z_hat = np.asarray(z_hat, dtype=int).reshape(-1)
        if z_hat.shape[0] != self.N:
            raise ValueError("z_hat length mismatch.")
        if int(np.sum(z_hat)) == 0:
            raise RuntimeError("Empty support (all zeros z_hat).")

        x = cp.Variable(self.N)
        Qpsd = cp.psd_wrap(self.Q)
        obj = cp.Minimize(0.5 * cp.quad_form(x, Qpsd))

        cons = [x >= 0.0, x <= z_hat.astype(float)]
        if self.sumx_eq:
            cons.append(cp.sum(x) == 1.0)
        else:
            cons.append(cp.sum(x) <= 1.0)

        prob = cp.Problem(obj, cons)
        self._solve_problem_with_fallback(prob, verbose=verbose)

        if prob.status not in ("optimal", "optimal_inaccurate") or x.value is None:
            raise RuntimeError(f"QP failed: status={prob.status}")

        x_val = np.asarray(x.value, dtype=float).reshape(-1)
        return x_val, float(prob.value)

    def _solve_fixed_support_relaxed_value(self, z_hat: np.ndarray, verbose: bool = False) -> float:
        _, val = self.solve_qp_with_support(z_hat=z_hat, verbose=verbose)
        return float(val)

    # -------------------------
    # surrogate H(alpha) on z
    # -------------------------
    def _build_effective_hamiltonian(self, alpha: float) -> np.ndarray:
        a = float(alpha)
        return 0.5 * (a * a) * self.Q

    # -------------------------
    # cardinality slack QUBO for sum(z) <= K_card
    # -------------------------
    def _build_z_only_qubo_with_slack(self, K_card: int, lam: float = 10.0):
        N = self.N
        K_card = int(max(1, K_card))
        K_eff = int(K_card)

        alpha_ref = 1.0 / float(K_eff)
        H_unscaled = self._build_effective_hamiltonian(alpha=alpha_ref)

        H_scale = float(np.max(np.abs(H_unscaled)))
        H_scale_used = H_scale if H_scale > 0 else 1.0
        H = H_unscaled / H_scale_used

        base = float(np.mean(np.abs(H))) if np.any(H) else 1.0
        lam_card = float(lam) * base

        self._last_qubo_meta = {
            "alpha_ref": float(alpha_ref),
            "K_card": int(K_card),
            "K_eff": int(K_eff),
            "H_scale": float(H_scale_used),
            "base": float(base),
            "lam_card": float(lam_card),
        }

        m1 = int(np.ceil(np.log2(K_card + 1))) if K_card > 0 else 1
        p1 = np.array([2**j for j in range(m1)], dtype=float)

        n_tot = N + m1
        Q = np.zeros((n_tot, n_tot), dtype=float)

        # FIX: correct mapping for H part
        H_qubo = self._quadratic_form_to_qubo_upper(H)
        Q[:N, :N] += H_qubo

        # penalty: (sum(z) + p1^T y - K_card)^2
        for i in range(N):
            Q[i, i] += lam_card * (1.0 - 2.0 * K_card)
        for i in range(N):
            for j in range(i + 1, N):
                Q[i, j] += 2.0 * lam_card

        for a in range(m1):
            ia = N + a
            Q[ia, ia] += lam_card * (p1[a] ** 2 - 2.0 * K_card * p1[a])
            for b in range(a + 1, m1):
                ib = N + b
                Q[ia, ib] += 2.0 * lam_card * p1[a] * p1[b]

        for i in range(N):
            for a in range(m1):
                ia = N + a
                Q[i, ia] += 2.0 * lam_card * p1[a]

        Q = np.triu(Q)
        const_scaled = lam_card * (K_card ** 2)
        return Q, const_scaled, N, m1, K_eff

    @staticmethod
    def _qubo_matrix_to_dict(Q: np.ndarray, tol: float = 0.0) -> dict[tuple[int, int], float]:
        Q = np.asarray(Q, dtype=float)
        n = Q.shape[0]
        qubo: dict[tuple[int, int], float] = {}
        for i in range(n):
            row = Q[i, i:]
            nz = np.where(np.abs(row) > tol)[0] if tol > 0 else np.where(row != 0.0)[0]
            for k in nz:
                j = i + int(k)
                qubo[(i, j)] = float(row[k])
        return qubo

    def _save_eps_eta_report(self, rows: list[dict[str, Any]], result_dir: str, result_tag: str) -> tuple[str, str]:
        out_dir = Path(result_dir)
        out_dir.mkdir(parents=True, exist_ok=True)

        def _dedup(p: Path) -> Path:
            if not p.exists():
                return p
            stem, suffix = p.stem, p.suffix
            i = 1
            while True:
                cand = p.with_name(f"{stem}_{i}{suffix}")
                if not cand.exists():
                    return cand
                i += 1

        json_path = _dedup(out_dir / f"{result_tag}_eps_eta.json")
        csv_path = json_path.with_suffix(".csv")

        payload = {"tag": result_tag, "N": int(self.N), "K": int(self.K), "rows": rows}
        json_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")

        fieldnames = sorted({k for r in rows for k in r.keys()})
        if not fieldnames:
            fieldnames = ["rank", "k", "E", "F_tilde", "eps", "eta"]

        with csv_path.open("w", newline="", encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
            w.writeheader()
            if rows:
                w.writerows(rows)

        return str(json_path), str(csv_path)

    # =========================
    # D-Wave QPU ONLY
    # =========================
    def solve_qubo(
        self,
        cardinality: Optional[int] = None,
        R: int = 10,
        num_reads: int = 2000,
        n_runs: int = 1,
        lam: float = 10.0,
        sampler: Optional[Any] = None,
        filter_empty: bool = True,
        save_eps_eta: bool = True,
        result_dir: str = "eps_eta_reports",
        result_tag: str = "run",
        qp_verbose: bool = False,

        # ---- F_tilde(z) frequency plot knobs ----
        plot_ftilde_freq: bool = True,
        ftilde_eval_top_z: int = 200,
        ftilde_bucket_decimals: int = 9,
        ftilde_plot_top_m: int = 80,

        # ---- normalize BQM to max|bias| ~= target ----
        bqm_maxabs_target: float = 1.0,
        auto_scale: bool = False,

        # ---- NEW: marginal knobs ----
        use_marginal: bool = True,
        marginal_top_z: Optional[int] = None,     # None => use all sampled bitstrings
        plot_marginal: bool = True,
        marginal_plot_top_m: int = 60,

        # ---- NEW: choose final z_hat ----
        final_pick: str = "best",  # "qsci" | "marginal" | "best"
    ) -> dict[str, Any]:
        K_card = int(cardinality) if (cardinality is not None and int(cardinality) > 0) else int(self.K)

        Qmat, const_scaled, N, m_card, K_eff = self._build_z_only_qubo_with_slack(K_card=K_card, lam=lam)

        qubo = self._qubo_matrix_to_dict(Qmat, tol=0.0)
        bqm = dimod.BQM.from_qubo(qubo)
        try:
            bqm.offset += float(const_scaled)
        except Exception:
            pass

        # --- force D-Wave QPU sampler ---
        if sampler is None:
            if DWaveSampler is None or EmbeddingComposite is None:
                raise RuntimeError(
                    "D-Wave sampler is required but not available.\n"
                    "Install/configure:\n"
                    "  pip install dwave-system\n"
                    "  dwave config create"
                )
            sampler = EmbeddingComposite(DWaveSampler())

        # normalize/scale BQM so max |bias| ~= target
        bqm_scale_factor = 1.0
        bqm_pre_maxabs = 0.0
        if bqm_maxabs_target is not None and float(bqm_maxabs_target) > 0:
            bqm, bqm_scale_factor, bqm_pre_maxabs = self._scale_bqm_maxabs(bqm, target=float(bqm_maxabs_target))
            self._last_qubo_meta["bqm_pre_maxabs"] = float(bqm_pre_maxabs)
            self._last_qubo_meta["bqm_scale_factor"] = float(bqm_scale_factor)
            self._last_qubo_meta["bqm_maxabs_target"] = float(bqm_maxabs_target)

        # -------------------------
        # sample
        # -------------------------
        z_counter: Counter[tuple[int, ...]] = Counter()
        for _ in range(int(n_runs)):
            sampleset = sampler.sample(bqm, num_reads=int(num_reads), auto_scale=bool(auto_scale))
            for rec in sampleset.data(fields=["sample", "num_occurrences"]):
                sample = rec.sample
                occ = int(getattr(rec, "num_occurrences", 1) or 1)
                z = tuple(int(sample[i]) for i in range(N))  # ignore slack bits
                if filter_empty and sum(z) == 0:
                    continue
                z_counter[z] += occ

        if not z_counter:
            raise RuntimeError("No valid z bitstrings from sampler")

        # SR: top-R bitstrings by occurrence
        SR = [z for z, _ in z_counter.most_common(int(R))]
        self.z_counter = z_counter
        self.SR = SR

        meta = self._last_qubo_meta or {}
        alpha_ref = float(meta.get("alpha_ref", 1.0))
        H_scale = float(meta.get("H_scale", 1.0))
        lam_card = float(meta.get("lam_card", 0.0))

        H_unscaled = self._build_effective_hamiltonian(alpha=alpha_ref)

        # -------------------------
        # eps/eta report on SR
        # -------------------------
        eps_eta_rows: Optional[list[dict[str, Any]]] = None
        eps_eta_json: Optional[str] = None
        eps_eta_csv: Optional[str] = None

        if save_eps_eta:
            eps_eta_rows = []
            for rank, z in enumerate(SR, start=1):
                z_hat_sr = np.asarray(z, dtype=int)
                k = int(np.sum(z_hat_sr))
                zf = z_hat_sr.astype(float).reshape(-1)

                E = float(zf @ H_unscaled @ zf)
                pen_card_scaled_min = float(lam_card * (max(0, k - K_card) ** 2))

                F_tilde = self._solve_fixed_support_relaxed_value(z_hat_sr, verbose=qp_verbose)
                eps = float("nan")
                eta = float(E - F_tilde) if np.isfinite(E) and np.isfinite(F_tilde) else float("nan")

                eps_eta_rows.append(
                    {
                        "rank": int(rank),
                        "k": int(k),
                        "E": float(E),
                        "F_tilde": float(F_tilde),
                        "eps": float(eps),
                        "eta": float(eta),
                        "alpha_ref": float(alpha_ref),
                        "H_scale": float(H_scale),
                        "pen_card_scaled_min": float(pen_card_scaled_min),
                        "K_card": int(K_card),
                        "K_eff": int(K_eff),
                        "bqm_pre_maxabs": float(bqm_pre_maxabs),
                        "bqm_scale_factor": float(bqm_scale_factor),
                        "bqm_maxabs_target": float(bqm_maxabs_target),
                    }
                )

            eps_eta_json, eps_eta_csv = self._save_eps_eta_report(
                rows=eps_eta_rows, result_dir=result_dir, result_tag=result_tag
            )

        # -------------------------
        # F_tilde(z) vs frequency
        # -------------------------
        ftilde_counter: Counter[float] = Counter()
        ftilde_plot_path: Optional[str] = None
        ftilde_eval_used = 0
        if plot_ftilde_freq:
            z_list = z_counter.most_common(int(max(1, ftilde_eval_top_z)))
            for z, occ in z_list:
                z_hat_sr = np.asarray(z, dtype=int)
                try:
                    fval = float(self._solve_fixed_support_relaxed_value(z_hat_sr, verbose=qp_verbose))
                except Exception:
                    continue
                fkey = self._bucket_float(fval, decimals=int(ftilde_bucket_decimals))
                ftilde_counter[fkey] += int(occ)
                ftilde_eval_used += 1

            if ftilde_counter:
                ftilde_plot_path = self._plot_ftilde_frequency(
                    ftilde_counter=ftilde_counter,
                    result_tag=result_tag,
                    out_dir="ftilde_plots",
                    top_m=int(ftilde_plot_top_m),
                    save=True,
                    show=False,
                )

        # -------------------------
        # QSCI generalized refine on SR
        # -------------------------
        X = np.array(SR, dtype=float)  # (R, N)
        HR = X @ H_unscaled @ X.T
        HR = 0.5 * (HR + HR.T)

        probs = self._qsci_generalized_weights(HR=HR, X=X, tol=1e-10, reg=1e-12)
        z_bar = probs @ X  # this is already a "marginal-like" vector over SR with overlap-aware weights

        plot_paths = self._plot_qsci_distribution(
            probs=probs,
            SR=SR,
            result_tag=result_tag,
            out_dir="qsci_plots",
            top_m=min(30, len(SR)),
            save=True,
            show=False,
        )

        # build z_hat from QSCI
        z_hat_qsci = np.zeros_like(z_bar, dtype=int)
        K_pick = int(max(1, min(K_eff, len(z_bar))))
        idx_qsci = np.argsort(z_bar)[-K_pick:]
        z_hat_qsci[idx_qsci] = 1

        # -------------------------
        # NEW: sample-marginal p_i = Pr(z_i=1) from all sampled strings
        # -------------------------
        p_marginal_sample: Optional[np.ndarray] = None
        z_hat_marginal: Optional[np.ndarray] = None
        marginal_plot_path: Optional[str] = None
        marginal_total_used: Optional[int] = None

        if use_marginal:
            p_marginal_sample, marginal_total_used = self._compute_sample_marginals(
                z_counter=z_counter,
                N=self.N,
                top_z=marginal_top_z,
            )
            self.p_marginal_sample = p_marginal_sample

            z_hat_marginal = np.zeros(self.N, dtype=int)
            idx_m = np.argsort(p_marginal_sample)[-K_pick:]
            z_hat_marginal[idx_m] = 1

            if plot_marginal:
                try:
                    marginal_plot_path = self._plot_marginals(
                        p=p_marginal_sample,
                        result_tag=result_tag,
                        out_dir="marginal_plots",
                        top_m=int(marginal_plot_top_m),
                        save=True,
                        show=False,
                    )
                except Exception:
                    marginal_plot_path = None

        # -------------------------
        # Solve QP for candidates and pick final
        # -------------------------
        x_qsci, obj_qsci = self.solve_qp_with_support(z_hat=z_hat_qsci, verbose=qp_verbose)

        x_marg, obj_marg = None, None
        if use_marginal and z_hat_marginal is not None:
            x_marg, obj_marg = self.solve_qp_with_support(z_hat=z_hat_marginal, verbose=qp_verbose)

        method = str(final_pick).lower().strip()
        if method not in ("qsci", "marginal", "best"):
            method = "best"

        if method == "qsci" or (not use_marginal) or (z_hat_marginal is None) or (obj_marg is None):
            z_hat_final = z_hat_qsci
            x_final = x_qsci
            obj_final = float(obj_qsci)
            picked = "qsci"
        elif method == "marginal":
            z_hat_final = z_hat_marginal
            x_final = np.asarray(x_marg, dtype=float)
            obj_final = float(obj_marg)
            picked = "marginal"
        else:
            # best-of-both
            if float(obj_marg) < float(obj_qsci):
                z_hat_final = z_hat_marginal
                x_final = np.asarray(x_marg, dtype=float)
                obj_final = float(obj_marg)
                picked = "marginal"
            else:
                z_hat_final = z_hat_qsci
                x_final = x_qsci
                obj_final = float(obj_qsci)
                picked = "qsci"

        # store
        self.z_bar = z_bar
        self.z_hat = z_hat_final
        self.x = x_final
        self.objective_value = float(obj_final)

        return {
            "K_card": int(K_card),
            "K_eff": int(K_eff),

            "SR_z": SR,
            "HR": HR,
            "qubo_const": float(const_scaled),
            "slack_bits_card": int(m_card),

            # QSCI outputs
            "qsci_probs": probs,
            "z_bar_qsci": z_bar,
            "z_hat_qsci": z_hat_qsci,
            "x_qsci": x_qsci,
            "objective_qsci": float(obj_qsci),
            "qsci_plot_paths": plot_paths,

            # Marginal outputs
            "use_marginal": bool(use_marginal),
            "p_marginal_sample": p_marginal_sample,
            "marginal_total_used": marginal_total_used,
            "z_hat_marginal": z_hat_marginal,
            "x_marginal": x_marg,
            "objective_marginal": (float(obj_marg) if obj_marg is not None else None),
            "marginal_plot_path": marginal_plot_path,

            # Final pick
            "final_pick": str(final_pick),
            "picked_method": picked,
            "z_hat": z_hat_final,
            "x": x_final,
            "objective": float(obj_final),

            # eps/eta
            "eps_eta_rows": eps_eta_rows,
            "eps_eta_json": eps_eta_json,
            "eps_eta_csv": eps_eta_csv,

            # F_tilde frequency
            "ftilde_plot_path": ftilde_plot_path,
            "ftilde_bucket_decimals": int(ftilde_bucket_decimals),
            "ftilde_eval_top_z": int(ftilde_eval_top_z),
            "ftilde_eval_used": int(ftilde_eval_used),
            "ftilde_freq_top": ftilde_counter.most_common(20),

            # BQM scaling info
            "bqm_pre_maxabs": float(bqm_pre_maxabs),
            "bqm_scale_factor": float(bqm_scale_factor),
            "bqm_maxabs_target": float(bqm_maxabs_target),
            "auto_scale": bool(auto_scale),
        }


