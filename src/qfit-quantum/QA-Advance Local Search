def configure_logging(verbose: bool, log_file: Optional[str] = None, append: bool = False) -> Path:
    """
    Configure root logging to console + ALWAYS file.

    - console:
        verbose=False => WARNING+
        verbose=True  => INFO+
    - file:
        ALWAYS INFO+  (even if verbose=False)
    """
    # default log file if user didn't provide one
    if not log_file or not str(log_file).strip():
        ts = time.strftime("%Y%m%d_%H%M%S")
        log_file = str(Path("logs") / f"run_{ts}.log")

    fmt = logging.Formatter(
        fmt="%(asctime)s %(levelname)s:%(name)s:%(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )

    root = logging.getLogger()

    # IMPORTANT:
    # root level must be <= INFO, otherwise INFO records won't be created at all
    root.setLevel(logging.INFO)

    # clear existing handlers to avoid duplicate logs
    for h in list(root.handlers):
        root.removeHandler(h)

    # console handler (level depends on verbose)
    console_level = logging.INFO if verbose else logging.WARNING
    sh = logging.StreamHandler()
    sh.setLevel(console_level)
    sh.setFormatter(fmt)
    root.addHandler(sh)

    # file handler (ALWAYS enabled, always INFO+)
    p = Path(log_file)
    if p.parent and str(p.parent) not in ("", "."):
        p.parent.mkdir(parents=True, exist_ok=True)
    mode = "a" if append else "w"
    fh = logging.FileHandler(str(p), mode=mode, encoding="utf-8")
    fh.setLevel(logging.INFO)
    fh.setFormatter(fmt)
    root.addHandler(fh)

    return p


