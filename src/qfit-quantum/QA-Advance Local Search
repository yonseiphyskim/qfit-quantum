    # 1-swap LS knobs
    parser.add_argument("--ls-iters", type=int, default=20, help="1-swap local search max iterations (default: 20)")
    parser.add_argument("--ls-active-pool", type=int, default=8, help="Candidates to remove (lowest confidence) (default: 8)")
    parser.add_argument("--ls-inactive-pool", type=int, default=64, help="Candidates to add (highest confidence) (default: 64)")
    parser.add_argument("--ls-tol", type=float, default=1e-10, help="Improvement tolerance (default: 1e-10)")
    parser.add_argument("--ls-first-improve", action="store_true", help="Use first-improvement instead of best-improvement")

    # ILS knobs (escape)
    parser.add_argument("--ils-kicks", type=int, default=30, help="Number of kicks (default: 30)")
    parser.add_argument("--ils-kick-size", type=int, default=3, help="How many swaps at once in kick (default: 3)")
    parser.add_argument("--ils-patience", type=int, default=8, help="Stop after this many non-improving kicks (default: 8)")
    parser.add_argument("--ils-restart-prob", type=float, default=0.2, help="Prob. of marginal-restart when stuck (default: 0.2)")
    parser.add_argument("--ils-mix-beta", type=float, default=0.2, help="Mix weight for marginal in kick scoring (default: 0.2)")
    parser.add_argument("--seed", type=int, default=0, help="Random seed for ILS (default: 0)")

    # D-Wave parameters
    parser.add_argument("--annealing-time", type=int, default=20, help="D-Wave annealing_time (microseconds)")
    parser.add_argument("--chain-strength", type=float, default=None, help="D-Wave chain_strength (default: auto)")
    parser.add_argument("--num-spin-reversal-transforms", type=int, default=0, help="D-Wave num_spin_reversal_transforms")

    args = parser.parse_args()

    # configure logging (console + ALWAYS file)
    log_path = configure_logging(verbose=bool(args.verbose), log_file=args.log_file, append=bool(args.log_append))

    # helper: print + log to file
    def tee(msg: str) -> None:
        print(msg)
        logger.info(msg)

    tee(f"[INFO] Logging to file: {log_path.resolve()}")

    # choose lp path
    lp_path: Path = Path("QPLIB_style_N300.lp")
    if args.lp is not None:
        lp_path = Path(args.lp)
    elif args.lp_pos is not None:
        lp_path = Path(args.lp_pos)

    if not lp_path.exists():
        tee(f"[ERROR] LP file not found: {lp_path}")
        sys.exit(1)

    tee(f"[INFO] Reading LP: {lp_path.resolve()}")

    # D-Wave sampler setup
    if DWaveSampler is None or EmbeddingComposite is None:
        tee(
            "[ERROR] D-Wave is required but not available.\n"
            "Install and configure:\n"
            "  pip install dwave-system\n"
            "  dwave config create"
        )
        sys.exit(2)

    qpu = DWaveSampler()
    sampler_base = EmbeddingComposite(qpu)

    if args.verbose:
        try:
            tee(f"[INFO] Using D-Wave QPU: {qpu.solver.name}")
        except Exception:
            tee("[INFO] Using D-Wave QPU")

    class _SamplerWrapper:
        def __init__(self, base, extra_kwargs: dict[str, Any]):
            self.base = base
            self.extra_kwargs = extra_kwargs

        def sample(self, bqm, **kwargs):
            merged = dict(self.extra_kwargs)
            merged.update(kwargs)
            return self.base.sample(bqm, **merged)

    extra_qpu_kwargs: dict[str, Any] = {
        "annealing_time": int(args.annealing_time),
    }
    if args.chain_strength is not None:
        extra_qpu_kwargs["chain_strength"] = float(args.chain_strength)
    if int(args.num_spin_reversal_transforms) > 0:
        extra_qpu_kwargs["num_spin_reversal_transforms"] = int(args.num_spin_reversal_transforms)

    sampler_obj = _SamplerWrapper(sampler_base, extra_qpu_kwargs)

    out = solve_qplib_style_lp(
        lp_path=str(lp_path),
        cardinality=args.K,
        num_reads=int(args.num_reads),
        n_runs=int(args.n_runs),
        lam=float(args.lam),
        sampler=sampler_obj,
        bqm_maxabs_target=float(args.bqm_maxabs_target),
        auto_scale=bool(args.auto_scale),
        marginal_best_frac=float(args.marginal_best_frac),
        plot_marginal=(not args.no_marginal_plot),
        marginal_plot_top_m=int(args.marginal_plot_top_m),
        ls_iters=int(args.ls_iters),
        ls_active_pool=int(args.ls_active_pool),
        ls_inactive_pool=int(args.ls_inactive_pool),
        ls_tol_improve=float(args.ls_tol),
        ls_first_improve=bool(args.ls_first_improve),
        ils_kicks=int(args.ils_kicks),
        ils_kick_size=int(args.ils_kick_size),
        ils_patience=int(args.ils_patience),
        ils_restart_prob=float(args.ils_restart_prob),
        ils_mix_beta=float(args.ils_mix_beta),
        qp_verbose=bool(args.qp_verbose),
        seed=int(args.seed),
        log_progress=bool(args.verbose),
        result_tag=args.tag,
    )

    # summary (tee => also in log file)
    tee("=== DONE ===")
    tee(f"LP              : {lp_path}")
    tee(f"K_card          : {out['K_card']}")
    tee(f"K_eff           : {out['K_eff']}")
    tee(f"K_pick          : {out['K_pick']}")

    tee(f"unique_z        : {out['num_unique_z']}")
    tee(f"total_occ       : {out['total_occ']}")
    tee(f"marg_best_frac  : {out['marginal_best_frac']}")
    tee(f"marg_occ_used   : {out['marginal_total_used']}")

    tee(f"bqm_pre_maxabs  : {out['bqm_pre_maxabs']}")
    tee(f"bqm_scale_factor: {out['bqm_scale_factor']}")
    tee(f"bqm_target      : {out['bqm_maxabs_target']}")
    tee(f"auto_scale      : {out['auto_scale']}")

    tee(f"objective_init  : {out['objective_init']:.12g}")
    tee(f"objective_ls    : {out['objective_ls']:.12g}")
    tee(f"objective_final : {out['objective']:.12g}")

    tee(f"active_init     : {out['active_init'][:30]}{' ...' if len(out['active_init']) > 30 else ''}")
    tee(f"active_ls       : {out['active_ls'][:30]}{' ...' if len(out['active_ls']) > 30 else ''}")
    tee(f"active_final    : {out['active_final'][:30]}{' ...' if len(out['active_final']) > 30 else ''}")

    if out.get("marginal_plot_path"):
        tee(f"marginal_plot   : {out['marginal_plot_path']}")

    ls_trace = out.get("ls_trace") or []
    if ls_trace:
        last = ls_trace[-1]
        tee(f"ls_steps        : {len(ls_trace)-1}")
        if "stop" in last:
            tee(f"ls_stop         : {last['stop']}")

    tee(f"ils_kicks_done  : {out.get('ils_kicks_done')}")
    tee(f"ils_stop        : {out.get('ils_stop_reason')}")

    tee(f"qp_calls_total  : {out.get('qp_solve_calls_total')}")
    tee(f"total_wall_s    : {out.get('timing_total_wall'):.3f}")
    tee("timing_breakdown:")
    timing = out.get("timing_breakdown") or {}
    for k, v in sorted(timing.items(), key=lambda kv: (-kv[1], kv[0])):
        tee(f"  {k:18s}: {v:.3f}s")
