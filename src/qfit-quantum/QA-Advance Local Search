def solve_qplib_style_lp(
    lp_path: str,
    cardinality: Optional[int] = None,
    num_reads: int = 3000,
    n_runs: int = 1,
    lam: float = 10.0,
    sampler: Optional[Any] = None,

    bqm_maxabs_target: float = 1.0,
    auto_scale: bool = False,

    marginal_best_frac: float = 0.2,
    plot_marginal: bool = True,
    marginal_plot_top_m: int = 60,

    ls_iters: int = 20,
    ls_active_pool: int = 8,
    ls_inactive_pool: int = 64,
    ls_tol_improve: float = 1e-10,
    ls_first_improve: bool = False,

    ils_kicks: int = 30,
    ils_kick_size: int = 3,
    ils_patience: int = 8,
    ils_restart_prob: float = 0.2,
    ils_mix_beta: float = 0.2,

    qp_verbose: bool = False,
    seed: int = 0,

    log_progress: bool = False,

    # NEW: allow manual tag (avoid filename parsing)
    result_tag: Optional[str] = None,
):
    Q, K, sumx_eq = read_qplib_style_lp(lp_path)
    tag = str(result_tag) if (result_tag is not None and str(result_tag).strip()) else Path(lp_path).stem

    solver = QPLIBStyleMIQPSolver(Q=Q, K=K, sumx_eq=sumx_eq)
    out = solver.solve(
        cardinality=cardinality,
        num_reads=num_reads,
        n_runs=n_runs,
        lam=lam,
        sampler=sampler,
        bqm_maxabs_target=float(bqm_maxabs_target),
        auto_scale=bool(auto_scale),
        marginal_best_frac=float(marginal_best_frac),
        plot_marginal=bool(plot_marginal),
        marginal_plot_top_m=int(marginal_plot_top_m),
        ls_iters=int(ls_iters),
        ls_active_pool=int(ls_active_pool),
        ls_inactive_pool=int(ls_inactive_pool),
        ls_tol_improve=float(ls_tol_improve),
        ls_first_improve=bool(ls_first_improve),
        ils_kicks=int(ils_kicks),
        ils_kick_size=int(ils_kick_size),
        ils_patience=int(ils_patience),
        ils_restart_prob=float(ils_restart_prob),
        ils_mix_beta=float(ils_mix_beta),
        qp_verbose=bool(qp_verbose),
        result_tag=tag,
        seed=int(seed),
        log_progress=bool(log_progress),
    )
    return out


